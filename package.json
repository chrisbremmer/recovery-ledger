{
  "name": "recovery-ledger",
  "version": "0.1.0",
  "description": "Local-first TypeScript CLI + MCP stdio server that turns WHOOP API v2 data into a daily/weekly review loop and a decision ledger. Not affiliated with WHOOP. BYO OAuth.",
  "type": "module",
  "bin": {
    "recovery-ledger": "./dist/cli.mjs",
    "recovery-ledger-mcp": "./dist/mcp.mjs"
  },
  "engines": {
    "node": ">=22.11"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev:cli": "tsx watch src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "docs:generate-api-gap": "tsx scripts/generate-api-gap-md.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "migrate:generate": "drizzle-kit generate",
    "check:circular": "madge --circular --extensions ts src/"
  },
  "private": true,
  "license": "UNLICENSED",
  "dependencies": {
    "@date-fns/tz": "^1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "simple-statistics": "^7.8.9",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/better-sqlite3": "^7",
    "@types/node": "^22",
    "@types/proper-lockfile": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "madge": "^8.0.0",
    "msw": "^2.14.6",
    "pino-pretty": "^13",
    "tsup": "^8.5",
    "tsx": "^4.21",
    "typescript": "^5.7",
    "vitest": "^4.1.6"
  }
}
